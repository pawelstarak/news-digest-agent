<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ subject }}</title>
</head>
<body style="margin:0;padding:0;background-color:#f5f5f0;font-family:Georgia,'Times New Roman',serif;">

<table width="100%" cellpadding="0" cellspacing="0" border="0" style="background-color:#f5f5f0;">
  <tr>
    <td align="center" style="padding:32px 16px;">

      <table width="640" cellpadding="0" cellspacing="0" border="0" style="max-width:640px;width:100%;background-color:#ffffff;border:1px solid #e0ddd6;">

        <!-- Header -->
        <tr>
          <td style="background-color:#1a1a1a;padding:28px 40px;">
            <p style="margin:0;font-family:Arial,Helvetica,sans-serif;font-size:11px;letter-spacing:2px;text-transform:uppercase;color:#888888;">Morning Digest</p>
            <h1 style="margin:8px 0 0 0;font-family:Georgia,'Times New Roman',serif;font-size:26px;font-weight:normal;color:#ffffff;">{{ subject }}</h1>
          </td>
        </tr>

        <!-- Body -->
        <tr>
          <td style="padding:0 40px;">

            {% for section in sections %}
            <!-- Category: {{ section.category_display_name }} -->
            <table width="100%" cellpadding="0" cellspacing="0" border="0">
              <tr>
                <td style="padding:32px 0 12px 0;border-bottom:2px solid #1a1a1a;">
                  <p style="margin:0;font-family:Arial,Helvetica,sans-serif;font-size:10px;letter-spacing:2px;text-transform:uppercase;color:#888888;">
                    {{ section.category_display_name }}{% if section.frequency == "weekly" %} &middot; Weekly{% endif %}
                  </p>
                </td>
              </tr>
            </table>

            {% for story in section.stories %}
            <table width="100%" cellpadding="0" cellspacing="0" border="0">
              <tr>
                <td style="padding:24px 0 {% if not loop.last %}0{% else %}8px{% endif %} 0;">

                  <!-- Story title -->
                  <h2 style="margin:0 0 4px 0;font-family:Georgia,'Times New Roman',serif;font-size:20px;font-weight:bold;line-height:1.3;">
                    <a href="{{ story.url }}" style="color:#1a1a1a;text-decoration:none;">{{ story.title }}</a>
                  </h2>

                  <!-- Source -->
                  <p style="margin:0 0 14px 0;font-family:Arial,Helvetica,sans-serif;font-size:11px;color:#888888;">
                    {{ story.source_name }}
                  </p>

                  <!-- Synthesis text -->
                  <div style="font-family:Georgia,'Times New Roman',serif;font-size:15px;line-height:1.7;color:#2c2c2c;">
                    {% for paragraph in story.synthesis_paragraphs %}
                    <p style="margin:0 0 12px 0;">{{ paragraph }}</p>
                    {% endfor %}
                  </div>

                </td>
              </tr>
              {% if not loop.last %}
              <tr>
                <td style="padding:0 0 0 0;border-bottom:1px solid #e0ddd6;"></td>
              </tr>
              {% endif %}
            </table>
            {% endfor %}

            {% endfor %}

          </td>
        </tr>

        <!-- Footer -->
        <tr>
          <td style="padding:24px 40px;border-top:1px solid #e0ddd6;background-color:#f9f8f6;">
            <p style="margin:0;font-family:Arial,Helvetica,sans-serif;font-size:11px;color:#aaaaaa;text-align:center;">
              Generated by News Digest Agent &middot; {{ generation_time }}
            </p>
          </td>
        </tr>

      </table>

    </td>
  </tr>
</table>

</body>
</html>
